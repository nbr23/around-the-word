<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }}</title>
  <style>
    :root {
      color-scheme: {% if dark_mode %}light dark{% else %}light{% endif %};
      --bg: white;
      --text: #333;
      --muted: #888;
      --muted-strong: #555;
      --panel-bg: white;
      --panel-border: #eee;
      --panel-shadow: rgba(0,0,0,0.15);
      --toggle-bg: rgba(0,0,0,0.06);
      --country-empty: #e0e0e0;
      --country-stroke: #fff;
      --country-stroke-hover: #555;
      --tooltip-border: transparent;
    }
    {% if dark_mode -%}
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1d2430;
        --text: #d8dce3;
        --muted: #8d95a2;
        --muted-strong: #c7cdd7;
        --panel-bg: #283040;
        --panel-border: #3c4454;
        --panel-shadow: rgba(0,0,0,0.4);
        --toggle-bg: rgba(255,255,255,0.08);
        --country-empty: #3a4252;
        --country-stroke: #1d2430;
        --country-stroke-hover: #d8dce3;
        --tooltip-border: rgba(255,255,255,0.18);
      }
    }
    {%- endif %}
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    h1 {
      text-align: center;
      padding: 1rem;
      font-size: 1.5rem;
      color: var(--text);
      background: var(--bg);
      box-shadow: 0 1px 3px var(--panel-shadow);
    }
    #map-container {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    svg {
      width: 100%;
      height: 100%;
    }
    .country {
      stroke: var(--country-stroke);
      stroke-width: 0.5;
      cursor: pointer;
      transition: stroke 0.1s, stroke-width 0.1s;
    }
    .country:hover {
      stroke: var(--country-stroke-hover);
      stroke-width: 1;
    }
    .tooltip {
      position: fixed;
      background: rgba(0,0,0,0.85);
      border: 1px solid var(--tooltip-border);
      color: white;
      padding: 8px 12px;
      border-radius: 4px;
      font-size: 14px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 1000;
      max-width: 200px;
    }
    .tooltip.visible {
      opacity: 1;
    }
    .tooltip-country {
      font-weight: 600;
      margin-bottom: 2px;
    }
    .tooltip-count {
      color: #ccc;
    }
    .tooltip-authors {
      margin-top: 6px;
      padding-top: 6px;
      border-top: 1px solid rgba(255,255,255,0.2);
      font-size: 12px;
    }
    .legend {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: var(--panel-bg);
      color: var(--text);
      padding: 12px;
      border-radius: 6px;
      box-shadow: 0 2px 8px var(--panel-shadow);
      font-size: 12px;
    }
    .legend-title {
      font-weight: 600;
      margin-bottom: 8px;
    }
    .legend-scale {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .legend-bar {
      width: 120px;
      height: 12px;
      border-radius: 2px;
    }
    .legend-list {
      margin-top: 10px;
      border-top: 1px solid var(--panel-border);
      padding-top: 8px;
    }
    .legend-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 2px 0;
    }
    .legend-item-count {
      color: var(--muted);
    }
    .toggle-container {
      position: fixed;
      top: 12px;
      right: 12px;
      z-index: 100;
    }
    .toggle {
      display: inline-flex;
      background: var(--toggle-bg);
      border-radius: 4px;
      padding: 2px;
    }
    .toggle-btn {
      padding: 4px 10px;
      border: none;
      background: transparent;
      border-radius: 3px;
      cursor: pointer;
      font-size: 11px;
      font-weight: 500;
      color: var(--muted);
      transition: all 0.15s;
    }
    .toggle-btn.active {
      background: var(--panel-bg);
      color: var(--muted-strong);
      box-shadow: 0 1px 2px var(--panel-shadow);
    }
    .toggle-btn:hover:not(.active) {
      color: var(--muted-strong);
    }
    .toggle-btn:focus-visible {
      outline: 2px solid var(--muted-strong);
      outline-offset: 1px;
    }
    @media (max-width: 600px) {
      h1 { font-size: 1.2rem; padding: 0.75rem; }
      .legend { bottom: 10px; right: 10px; padding: 8px; font-size: 11px; }
      .legend-bar { width: 80px; }
      .toggle-container { top: 8px; right: 8px; }
      .toggle-btn { padding: 3px 8px; font-size: 10px; }
    }
  </style>
</head>
<body>
  {% if map_title %}<h1>{{ map_title }}</h1>{% endif %}
  {% if has_book_data %}
  <div class="toggle-container">
    <div class="toggle">
      <button class="toggle-btn{% if default_view == 'authors' %} active{% endif %}" data-mode="authors" aria-pressed="{{ 'true' if default_view == 'authors' else 'false' }}" title="Count unique authors per country">Authors</button>
      <button class="toggle-btn{% if default_view == 'books' %} active{% endif %}" data-mode="books" aria-pressed="{{ 'true' if default_view == 'books' else 'false' }}" title="Count total books per country">Books</button>
    </div>
  </div>
  {% endif %}
  <div id="map-container"></div>
  <div class="tooltip" id="tooltip">
    <div class="tooltip-country"></div>
    <div class="tooltip-count"></div>
    <div class="tooltip-authors"></div>
  </div>
  {% if show_legend %}
  <div class="legend">
    <div class="legend-title" id="legend-title"></div>
    <div class="legend-scale">
      <span>1</span>
      <div class="legend-bar" id="legend-bar"></div>
      <span id="legend-max"></span>
    </div>
    {% if top_n %}<div class="legend-list" id="legend-list"></div>{% endif %}
  </div>
  {% endif %}
  <script>{{ d3_js | safe }}</script>
  <script>{{ topojson_js | safe }}</script>
  <script>
    const topoData = {{ topojson_data | safe }};
    const authorCounts = {{ author_counts | tojson }};
    const bookCounts = {{ book_counts | tojson }};
    const hasBookData = {{ has_book_data | tojson }};
    const colorScaleName = {{ color_scale | tojson }};
    const authorsByCountry = {{ authors_by_country | tojson }};

    const authorToCountries = {};
    Object.entries(authorsByCountry).forEach(([country, authors]) => {
      authors.forEach(author => {
        (authorToCountries[author] = authorToCountries[author] || []).push(country);
      });
    });

    let currentMode = "{{ default_view }}";
    let currentCounts = currentMode === "books" ? bookCounts : authorCounts;
    let currentLabel = currentMode === "books" ? "book" : "author";

    const params = new URLSearchParams(window.location.search);
    let filterCountry = params.get('country');
    let filterAuthor = params.get('author');
    let filterAuthorList = null;

    function updateURL() {
      const p = new URLSearchParams();
      if (filterCountry) p.set('country', filterCountry);
      if (filterAuthor) p.set('author', filterAuthor);
      const qs = p.toString();
      history.replaceState(null, '', qs ? '?' + qs : window.location.pathname);
    }

    function getFilteredCounts() {
      if (filterAuthorList) {
        const filtered = {};
        const authors = currentMode === "books" ? filterAuthorList : [...new Set(filterAuthorList)];
        authors.forEach(author => {
          (authorToCountries[author] || []).forEach(country => {
            filtered[country] = (filtered[country] || 0) + 1;
          });
        });
        return filtered;
      }
      if (!filterCountry && !filterAuthor) return currentCounts;
      const filtered = {};
      if (filterAuthor) {
        Object.keys(authorsByCountry).forEach(country => {
          if (authorsByCountry[country].some(a => a === filterAuthor) && currentCounts[country]) {
            filtered[country] = currentCounts[country];
          }
        });
      } else if (filterCountry) {
        if (currentCounts[filterCountry]) {
          filtered[filterCountry] = currentCounts[filterCountry];
        }
      }
      return filtered;
    }

    function emptyFill() {
      return getComputedStyle(document.documentElement).getPropertyValue('--country-empty').trim() || '#e0e0e0';
    }

    const lightStartScales = new Set([
      "interpolateReds", "interpolateBlues", "interpolateGreens", "interpolateOranges",
      "interpolatePurples", "interpolateGreys", "interpolateYlGnBu", "interpolateYlOrBr"
    ]);
    const darkModeEnabled = {{ dark_mode | tojson }};
    const darkScheme = window.matchMedia('(prefers-color-scheme: dark)');

    function getInterpolator() {
      const base = d3[colorScaleName] || d3.interpolateReds;
      if (darkModeEnabled && darkScheme.matches && lightStartScales.has(colorScaleName)) {
        const bg = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#1d2430';
        const low = d3.interpolateRgb(base(0.85), bg)(0.55);
        const high = base(0.4);
        return d3.interpolateLab(low, high);
      }
      return base;
    }

    function applyFilters() {
      const filtered = getFilteredCounts();
      dataByTopoName = getDataByTopoName(filtered);
      maxCount = Math.max(...Object.values(filtered), 1);

      color = d3.scaleSequentialLog()
        .domain([1, maxCount])
        .interpolator(getInterpolator());

      svg.selectAll('.country')
        .transition()
        .duration(300)
        .attr('fill', d => {
          const name = d.properties.name;
          const count = dataByTopoName[name] || 0;
          return count > 0 ? color(count) : emptyFill();
        });

      {% if show_legend %}
      updateLegend();
      {% endif %}
    }

    const countryNameMap = {
      "United States": "United States of America",
      "Czech Republic": "Czechia",
      "Dominican Republic": "Dominican Rep.",
      "Ivory Coast": "Côte d'Ivoire",
      "Central African Republic": "Central African Rep.",
      "Equatorial Guinea": "Eq. Guinea",
      "North Macedonia": "Macedonia",
      "Bosnia and Herzegovina": "Bosnia and Herz.",
      "Swaziland": "eSwatini",
      "South Sudan": "S. Sudan",
      "Congo, Democratic Republic": "Dem. Rep. Congo",
      "Trinidad and Tobago": "Trinidad and Tobago"
    };

    const topoToDisplayName = {};
    Object.entries(countryNameMap).forEach(([display, topo]) => {
      topoToDisplayName[topo] = display;
    });

    function getDataByTopoName(counts) {
      const data = {};
      Object.entries(counts).forEach(([name, count]) => {
        const topoName = countryNameMap[name] || name;
        data[topoName] = count;
      });
      return data;
    }

    let dataByTopoName = getDataByTopoName(currentCounts);
    let maxCount = Math.max(...Object.values(currentCounts), 1);

    const container = document.getElementById('map-container');
    const width = container.clientWidth;
    const height = container.clientHeight;

    const countries = topojson.feature(topoData, topoData.objects.countries);

    const svg = d3.select('#map-container')
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('preserveAspectRatio', 'xMidYMid meet')
      .attr('role', 'img')
      .attr('aria-label', {{ map_title | tojson }} || 'World map of author nationalities');

    const projection = d3.geoNaturalEarth1()
      .fitSize([width, height], countries);

    const path = d3.geoPath().projection(projection);

    let color = d3.scaleSequentialLog()
      .domain([1, maxCount])
      .interpolator(getInterpolator());

    let clickTimer = null;

    svg.selectAll('.country')
      .data(countries.features)
      .enter()
      .append('path')
      .attr('class', 'country')
      .attr('d', path)
      .attr('fill', d => {
        const name = d.properties.name;
        const count = dataByTopoName[name] || 0;
        return count > 0 ? color(count) : emptyFill();
      })
      .on('mouseover', showTooltip)
      .on('mousemove', moveTooltip)
      .on('mouseout', hideTooltip)
      .on('touchstart', showTooltip, { passive: true })
      .on('touchend', hideTooltip, { passive: true })
      .on('click', function(event, d) {
        if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; }
        clickTimer = setTimeout(() => {
          filterCountry = null;
          filterAuthor = null;
          filterAuthorList = null;
          updateURL();
          applyFilters();
          parent.postMessage({ type: 'clear' }, '*');
          clickTimer = null;
        }, 250);
      })
      .on('dblclick', function(event, d) {
        if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; }
        const topoName = d.properties.name;
        const displayName = topoToDisplayName[topoName] || topoName;
        filterCountry = displayName;
        filterAuthor = null;
        updateURL();
        applyFilters();
        parent.postMessage({ type: 'filterCountry', country: displayName }, '*');
      });

    svg.on('click', function(event) {
      if (event.target.tagName === 'svg' || event.target === svg.node()) {
        if (filterCountry || filterAuthor || filterAuthorList) {
          filterCountry = null;
          filterAuthor = null;
          filterAuthorList = null;
          updateURL();
          applyFilters();
          parent.postMessage({ type: 'clear' }, '*');
        }
      }
    });

    const tooltip = document.getElementById('tooltip');
    const tooltipCountry = tooltip.querySelector('.tooltip-country');
    const tooltipCount = tooltip.querySelector('.tooltip-count');
    const tooltipAuthors = tooltip.querySelector('.tooltip-authors');

    function showTooltip(event, d) {
      const topoName = d.properties.name;
      const displayName = topoToDisplayName[topoName] || topoName;
      const count = dataByTopoName[topoName] || 0;

      tooltipCountry.textContent = displayName;
      tooltipCount.textContent = count > 0 ? `${count} ${currentLabel}${count !== 1 ? 's' : ''}` : `No ${currentLabel}s`;

      let authors = authorsByCountry[displayName] || [];
      if (filterAuthorList) {
        const yearAuthors = new Set(filterAuthorList);
        authors = authors.filter(a => yearAuthors.has(a));
      }
      tooltipAuthors.textContent = '';
      authors.forEach(a => {
        const div = document.createElement('div');
        div.textContent = a;
        tooltipAuthors.appendChild(div);
      });

      tooltip.classList.add('visible');
      moveTooltip(event);
    }

    function moveTooltip(event) {
      const e = event.touches ? event.touches[0] : event;
      const x = e.clientX;
      const y = e.clientY;

      const rect = tooltip.getBoundingClientRect();
      const left = Math.min(x + 10, window.innerWidth - rect.width - 10);
      const top = Math.min(y + 10, window.innerHeight - rect.height - 10);

      tooltip.style.left = left + 'px';
      tooltip.style.top = top + 'px';
    }

    function hideTooltip() {
      tooltip.classList.remove('visible');
    }

    function switchMode(mode) {
      if (mode === currentMode) return;
      currentMode = mode;
      currentCounts = mode === "books" ? bookCounts : authorCounts;
      currentLabel = mode === "books" ? "book" : "author";

      document.querySelectorAll('.toggle-btn').forEach(btn => {
        const active = btn.dataset.mode === mode;
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-pressed', active);
      });

      applyFilters();
    }

    {% if has_book_data %}
    document.querySelectorAll('.toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => switchMode(btn.dataset.mode));
    });
    {% endif %}

    {% if show_legend %}
    const legendTitle = document.getElementById('legend-title');
    const legendBar = document.getElementById('legend-bar');
    const legendMax = document.getElementById('legend-max');
    {% if top_n %}const legendList = document.getElementById('legend-list');{% endif %}

    function updateLegend() {
      legendTitle.textContent = currentLabel.charAt(0).toUpperCase() + currentLabel.slice(1) + 's';
      legendMax.textContent = maxCount;

      const gradientStops = [];
      for (let i = 0; i <= 10; i++) {
        gradientStops.push(color(Math.max(1, Math.pow(maxCount, i / 10))));
      }
      legendBar.style.background = `linear-gradient(to right, ${gradientStops.join(', ')})`;
      {% if top_n %}
      const topN = Object.entries(getFilteredCounts())
        .sort((a, b) => b[1] - a[1])
        .slice(0, {{ top_n }});
      legendList.textContent = '';
      topN.forEach(([country, count]) => {
        const item = document.createElement('div');
        item.className = 'legend-item';
        const name = document.createElement('span');
        name.textContent = country;
        const value = document.createElement('span');
        value.className = 'legend-item-count';
        value.textContent = count;
        item.append(name, value);
        legendList.appendChild(item);
      });
      {% endif %}
    }
    updateLegend();
    {% endif %}

    if (filterCountry || filterAuthor) applyFilters();

    window.addEventListener('message', function(e) {
      var data = e.data;
      if (!data || !data.type) return;
      if (data.type === 'filterAuthors' && data.authors) {
        filterCountry = null;
        filterAuthor = null;
        filterAuthorList = data.authors;
        applyFilters();
        return;
      } else if (data.type === 'filterAuthor' && data.author) {
        filterCountry = null;
        filterAuthor = data.author;
        filterAuthorList = null;
      } else if (data.type === 'filterCountry' && data.country) {
        filterAuthor = null;
        filterCountry = data.country;
        filterAuthorList = null;
      } else if (data.type === 'clear') {
        filterCountry = null;
        filterAuthor = null;
        filterAuthorList = null;
      } else {
        return;
      }
      updateURL();
      applyFilters();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && (filterCountry || filterAuthor || filterAuthorList)) {
        filterCountry = null;
        filterAuthor = null;
        filterAuthorList = null;
        updateURL();
        applyFilters();
        parent.postMessage({ type: 'clear' }, '*');
      }
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', applyFilters);

    window.addEventListener('resize', () => {
      const newWidth = container.clientWidth;
      const newHeight = container.clientHeight;
      projection.fitSize([newWidth, newHeight], countries);
      svg.attr('viewBox', `0 0 ${newWidth} ${newHeight}`);
      svg.selectAll('.country').attr('d', path);
    });
  </script>
</body>
</html>
